# ==============================
# GMGN OpenAPI
# ==============================
GMGN_API_KEY=your_gmgn_api_key_here
GMGN_API_HOST=https://openapi.gmgn.ai
GMGN_CHAIN=sol
GMGN_RANK_LIMIT=100
GMGN_INTERVALS=5m,1h
GMGN_REQUEST_TIMEOUT_MS=15000
GMGN_RETRY_ATTEMPTS=3
GMGN_KOL_HOLDERS_LIMIT=30

# ==============================
# Discord
# ==============================
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_target_channel_id_here
DISCORD_MENTION_ROLE_ID=

# ==============================
# Scan interval & filters
# ==============================
CHECK_INTERVAL_MS=300000
MIN_MARKET_CAP=200000
MIN_VOLUME_1H=50000
MIN_TOTAL_FEES_SOL=20
MIN_HOLDERS=500

# true = print only (no Discord send)
DRY_RUN=true
